{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/pr-provenance-stamp.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/pr-provenance-stamp.js\""
          }
        ]
      }
    ]
  }
}
