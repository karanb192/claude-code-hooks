{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dead-end-registry.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dead-end-registry.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dead-end-registry.js\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dead-end-registry.js\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dead-end-registry.js\""
          }
        ]
      }
    ]
  }
}
